{
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm --filter @agent-flow/frontend dev",
    "dev:backend": "pnpm --filter @agent-flow/backend dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "storybook": "pnpm --filter @agent-flow/frontend storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2"
  }
}
